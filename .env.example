# MySQL Database Configuration
# Gunakan 'host.docker.internal' jika MySQL ada di Host OS (Windows/Linux)
# Gunakan 'db' sebagai host jika MySQL ada di container Docker lain dalam satu network
DATABASE_URL=mysql://user:pass@localhost:3306/admin_db
MIKHMON_DATABASE_URL=mysql://user:pass@localhost:3306/mikhmon

# Server Configuration (Internal Container)
HOST=0.0.0.0
PORT=8080

# Security (Ganti dengan secret yang sangat kuat)
JWT_SECRET=secret

# Production Ports Mapping (Exposed to Host)
# Port yang akan digunakan Nginx Reverse Proxy untuk forward traffic
APP_FRONTEND_PORT=8089
APP_BACKEND_PORT=8080

# Frontend URL for CORS (Akses publik atau localhost)
FRONTEND_URL=http://localhost:8089
